{
  "info": {
    "_postman_id": "e3f6d6b2-0b9f-4c23-9c85-2c2b7b6a2c01",
    "name": "Pluma Parkinson's Intake — Smoke Test",
    "description": "End-to-end smoke test for the SSR + API service:\n1. /api/health liveness\n2. POST /api/submissions happy path (201 + saves an id for step 4)\n3. POST /api/submissions rejection path (400, Zod validator rejects)\n4. GET /api/submissions/:id (200, round-trips the encrypted payload)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Smoke",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('ok:true', () => pm.expect(body.ok).to.equal(true));",
                  "pm.test('submissions is a number', () => pm.expect(body.submissions).to.be.a('number'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/submissions (valid)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/submissions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "submissions"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemaVersion\": \"1.0\",\n  \"generatedAt\": \"{{$isoTimestamp}}\",\n  \"zipCode\": \"90210\",\n  \"ageBand\": \"60-69\",\n  \"sexAtBirth\": \"male\",\n  \"markdown\": \"Smoke-test submission — no PII in this body.\",\n  \"sections\": []\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('ok:true', () => pm.expect(body.ok).to.equal(true));",
                  "pm.test('returns a UUID id', () => pm.expect(body.id).to.match(/^[0-9a-f-]{36}$/i));",
                  "pm.collectionVariables.set('submissionId', body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/submissions (invalid — Zod rejects)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/submissions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "submissions"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemaVersion\": \"1.0\",\n  \"generatedAt\": \"{{$isoTimestamp}}\",\n  \"zipCode\": \"bad\",\n  \"markdown\": \"leak: contact me at a@b.co\",\n  \"sections\": [],\n  \"firstName\": \"Jane\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('400 Bad Request', () => pm.response.to.have.status(400));",
                  "const body = pm.response.json();",
                  "pm.test('ok:false', () => pm.expect(body.ok).to.equal(false));",
                  "pm.test('errors array present', () => pm.expect(body.errors).to.be.an('array').that.is.not.empty);",
                  "const fields = body.errors.map(e => e.field);",
                  "pm.test('flags firstName as direct PII', () => pm.expect(fields).to.include('firstName'));",
                  "pm.test('flags zipCode format', () => pm.expect(fields).to.include('zipCode'));",
                  "pm.test('flags email leak in markdown', () => pm.expect(fields).to.include('markdown'));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/submissions/:id (round-trip)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/submissions/{{submissionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "submissions", "{{submissionId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('id matches the saved one', () => pm.expect(body.id).to.equal(pm.collectionVariables.get('submissionId')));",
                  "pm.test('markdown decrypted round-trip', () => pm.expect(body.markdown).to.include('Smoke-test submission'));",
                  "pm.test('zipCode decrypted round-trip', () => pm.expect(body.zipCode).to.equal('90210'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:4000", "type": "string" },
    { "key": "submissionId", "value": "", "type": "string" }
  ]
}
