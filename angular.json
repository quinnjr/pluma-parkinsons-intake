{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "pnpm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "pluma-parkinsons-intake": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "server": "src/main.server.ts",
            "ssr": {
              "entry": "src/server/main.ts"
            },
            "prerender": false,
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*.csv",
                "input": "prisma/data",
                "output": "prisma/data"
              }
            ],
            "styles": [
              "src/styles.css"
            ],
            "externalDependencies": [
              "better-sqlite3",
              "@prisma/adapter-better-sqlite3",
              "@prisma/client",
              "argon2"
            ],
            "allowedCommonJsDependencies": [
              "dotenv/config",
              "reflect-metadata"
            ],
            "subresourceIntegrity": true
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "600kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": {
                  "inline": false
                }
              }
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "pluma-parkinsons-intake:build:production"
            },
            "development": {
              "buildTarget": "pluma-parkinsons-intake:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "pluma-parkinsons-intake:build:development",
            "runner": "vitest",
            "setupFiles": ["src/test-setup.ts"],
            "include": ["src/**/*.spec.ts"],
            "coverageInclude": [
              "src/server/**/*.ts",
              "src/app/shared/api-client.ts",
              "src/app/shared/api-errors.ts",
              "src/app/shared/auth.guard.ts",
              "src/app/shared/auth.service.ts",
              "src/app/shared/superfund.service.ts",
              "src/app/shared/validation.ts",
              "src/app/shared/webauthn.service.ts",
              "src/app/shared/us-states.ts",
              "src/app/risk/risk.service.ts",
              "src/app/risk/submission-api.service.ts"
            ],
            "coverageExclude": [
              "src/**/*.spec.ts",
              "src/**/*.d.ts",
              "src/server/express-augmentation.d.ts",
              "src/server/main.ts",
              "src/server/mailer.ts",
              "src/server/test-db.ts",
              "src/server/test-app.ts"
            ],
            "coverageReporters": ["text", "text-summary", "html"],
            "coverageThresholds": {
              "lines": 90,
              "functions": 90,
              "branches": 85,
              "statements": 90
            }
          }
        }
      }
    }
  }
}
