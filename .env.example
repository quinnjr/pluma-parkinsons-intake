# Copy to `.env` and fill in real values. Never commit `.env`.

# Prisma — SQLite at project root
DATABASE_URL="file:./dev.db"

# AES-256-GCM key-derivation secret (scrypt → 32 bytes). Must be >= 16 chars.
# Generate with: openssl rand -base64 48
# Changing this value invalidates all existing ciphertext — data cannot be read back.
ENCRYPTION_SECRET="replace-me-with-openssl-rand-base64-48"

# HMAC secret used to sign admin JWTs. Must be >= 32 chars.
# Generate with: openssl rand -base64 48
# Rotating this invalidates all outstanding sessions (everyone is logged out).
JWT_SECRET="replace-me-with-openssl-rand-base64-48"

# Email address allowed to claim the root admin account via /admin/signup.
# Only the first signup with this email succeeds; subsequent ones are rejected.
ROOT_ADMIN_EMAIL="admin@example.com"

# API server port (optional, defaults to 4000)
# PORT=4000

# WebAuthn / passkeys — relying-party config.
# rpId must match the domain the browser sees. origin is the full scheme+host
# (comma-separated for dev/prod if needed).
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_NAME=Pluma
# WEBAUTHN_ORIGIN=http://localhost:4000

# Comma-separated hostnames allowed by Angular SSR's CommonEngine.
# NG_ALLOWED_HOSTS=localhost,127.0.0.1
